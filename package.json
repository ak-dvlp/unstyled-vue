{
  "name": "styleless-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Набор компонентов пользовательского интерфейса",
  "main": "src/main.ts",
  "repository": "git@github.com:Aleksandr-86/unstyled-vue.git",
  "author": "Aleksandr-86 <Aleksandr-Karpenko-86@yandex.ru>",
  "license": "MIT",
  "scripts": {
    "demo": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "test-ct": "playwright test -c playwright-ct.config.ts --ui"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.1",
    "tailwindcss": "4.3.1",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@playwright/experimental-ct-vue": "1.61.1",
    "@playwright/test": "1.61.1",
    "@tsconfig/node24": "24.0.4",
    "@types/jsdom": "28.0.3",
    "@types/node": "26.0.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/eslint-plugin": "1.6.20",
    "@vue/eslint-config-typescript": "14.9.0",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-vue": "10.9.2",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "prettier-plugin-css-order": "2.2.0",
    "prettier-plugin-organize-attributes": "1.0.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "sass": "1.101.0",
    "sass-loader": "17.0.0",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-vue-devtools": "8.1.1",
    "vitest": "4.1.9",
    "vue-tsc": "3.3.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
