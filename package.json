{
  "name": "styleless-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Набор компонентов пользовательского интерфейса",
  "main": "src/main.ts",
  "repository": "git@github.com:Aleksandr-86/unstyled-vue.git",
  "author": "Aleksandr-86 <Aleksandr-Karpenko-86@yandex.ru>",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "test-ct": "playwright test -c playwright-ct.config.ts --ui"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.2",
    "tailwindcss": "4.2.2",
    "vue": "3.5.32",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@playwright/experimental-ct-vue": "1.59.1",
    "@playwright/test": "1.59.1",
    "@tsconfig/node24": "24.0.4",
    "@types/jsdom": "28.0.1",
    "@types/node": "25.5.2",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitest/eslint-plugin": "1.6.14",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-playwright": "2.10.1",
    "eslint-plugin-vue": "10.8.0",
    "jiti": "2.6.1",
    "jsdom": "29.0.1",
    "npm-check-updates": "20.0.0",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.1",
    "prettier-plugin-css-order": "2.2.0",
    "prettier-plugin-organize-attributes": "1.0.0",
    "prettier-plugin-tailwindcss": "0.6.9",
    "sass": "1.99.0",
    "sass-loader": "16.0.7",
    "typescript": "6.0.2",
    "vite": "8.0.5",
    "vite-plugin-vue-devtools": "8.1.1",
    "vitest": "4.1.2",
    "vue-tsc": "3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
